# ============================================================
# P2-A: TikTok Read-Only Live Feed
# ============================================================
TIKTOK_USERNAME=interiorhack.id

# ============================================================
# P2-B: LLM + TTS Reply Loop
# ============================================================

# --- LiteLLM Router (3-tier fallback) ---
# Tier 1: 9router (free, rate-limited)
NINEROUTER_BASE_URL=https://9router.com/v1
NINEROUTER_API_KEY=your-9router-key-here

# Tier 2: DeepSeek (cheap, ~Rp 1.5/reply)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# Tier 3: Claude Haiku (fallback, ~Rp 5/reply)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
CLAUDE_MODEL=claude-3-haiku-20240307

# LLM Params
LLM_MAX_TOKENS=150
LLM_TEMPERATURE=0.7

# --- Cartesia TTS Pool (comma-separated, 1 or more keys) ---
CARTESIA_API_KEYS=your-cartesia-key-1,your-cartesia-key-2,your-cartesia-key-3,your-cartesia-key-4,your-cartesia-key-5
CARTESIA_VOICE_ID=a167e0f3-df7e-4d52-a9c3-f949145efdab
CARTESIA_MODEL=sonic-3

# --- Edge-TTS Fallback ---
EDGE_TTS_VOICE=id-ID-ArdiNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%

# --- Guardrail ---
FORBIDDEN_PATTERNS=http,https,wa.me,t.me,08,62,link,promo,diskon
MAX_COMMENT_LENGTH=200
RATE_LIMIT_REPLIES_PER_MIN=8
DEDUP_WINDOW_SEC=60

# --- Cost & Budget ---
BUDGET_IDR_DAILY=50000
NINEROUTER_COST_PER_1K_TOKENS=0.0
DEEPSEEK_COST_PER_1K_INPUT=0.0014
DEEPSEEK_COST_PER_1K_OUTPUT=0.0028
CLAUDE_COST_PER_1K_INPUT=0.00025
CLAUDE_COST_PER_1K_OUTPUT=0.00125
CARTESIA_COST_PER_SEC=0.00001
USD_TO_IDR=15800

# --- Feature Flags ---
REPLY_ENABLED=false
DRY_RUN=true

# ============================================================
# IPC & Logging
# ============================================================
WS_HOST=127.0.0.1
WS_PORT=8765
HTTP_HOST=127.0.0.1
HTTP_PORT=8766
LOG_LEVEL=INFO
LOG_DIR=logs

# ============================================================
# v0.4 — Live Orchestrator
# ============================================================
AUDIO_LIBRARY_DIR=static/audio_library
CLIPS_SCRIPT_YAML=config/clips_script.yaml
PRODUCTS_YAML=config/products.yaml
REPLY_TEMPLATES_YAML=config/reply_templates.yaml
LIVE_MAX_DURATION_S=7200
REPLY_CACHE_TTL_S=300
REPLY_CACHE_SIMILARITY=0.90
CLASSIFIER_LLM_THRESHOLD=0.80
