# TikTok Configuration
TIKTOK_USERNAME=interiorhack.id

# LLM Configuration
# DeepSeek (Primary)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=150
DEEPSEEK_TEMPERATURE=0.7

# Claude (Fallback)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
CLAUDE_MODEL=claude-3-haiku-20240307
CLAUDE_MAX_TOKENS=150

# TTS Configuration
TTS_VOICE=id-ID-ArdiNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# Rate Limiting
MAX_REPLIES_PER_MINUTE=8
MIN_SECONDS_BETWEEN_REPLIES=4

# OBS Configuration
OBS_TEXT_FILE_PATH=obs/last_reply.txt

# IPC Configuration
WS_HOST=127.0.0.1
WS_PORT=8765
HTTP_HOST=127.0.0.1
HTTP_PORT=8766

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Cost Tracking
DEEPSEEK_COST_PER_1K_INPUT_TOKENS=0.0014
DEEPSEEK_COST_PER_1K_OUTPUT_TOKENS=0.0028
CLAUDE_COST_PER_1K_INPUT_TOKENS=0.00025
CLAUDE_COST_PER_1K_OUTPUT_TOKENS=0.00125
CURRENCY_RATE_USD_TO_IDR=15800

# Feature Flags
DRY_RUN_MODE=false
ENABLE_CLAUDE_FALLBACK=true
ENABLE_GIFT_REPLIES=true
ENABLE_FOLLOW_REPLIES=true
